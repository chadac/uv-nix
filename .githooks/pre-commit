#!/usr/bin/env bash
# Pre-commit hook: run formatting and lint checks
set -euo pipefail

# Only check if Rust files are staged
if git diff --cached --name-only | grep -qE '\.(rs|toml)$'; then
    echo "Running cargo fmt check..."
    cargo fmt -- --check || {
        echo "ERROR: cargo fmt check failed. Run 'just fmt' to fix."
        exit 1
    }

    echo "Running cargo clippy..."
    cargo clippy --all-targets -- -D warnings || {
        echo "ERROR: clippy warnings found. Run 'cargo clippy --fix' to fix."
        exit 1
    }
fi
