+#[derive(Args)]
+pub struct NixNamespace {
+    #[command(subcommand)]
+    pub command: NixCommand,
+}
+
+#[derive(Subcommand)]
+pub enum NixCommand {
+    /// Patch ELF binaries in a virtual environment for NixOS compatibility.
+    Patch(NixPatchArgs),
+    /// Show information about patched packages in a virtual environment.
+    Info(NixInfoArgs),
+    /// Generate Nix expressions for uv2nix from patch data.
+    Gen(NixGenArgs),
+}
+
+#[derive(Args)]
+pub struct NixPatchArgs {
+    /// Path to the virtual environment to patch.
+    /// Defaults to UV_PROJECT_ENVIRONMENT, VIRTUAL_ENV, or .venv.
+    pub path: Option<PathBuf>,
+    /// Only patch the Python interpreter, not packages.
+    #[arg(long, conflicts_with = "only_packages")]
+    pub only_python: bool,
+    /// Only patch packages, not the Python interpreter.
+    #[arg(long, conflicts_with = "only_python")]
+    pub only_packages: bool,
+    /// Specific packages to patch (comma-separated). If not specified, patches all.
+    #[arg(long, value_delimiter = ',')]
+    pub packages: Option<Vec<String>>,
+    /// Path to the patchelf binary (Linux) or install_name_tool (macOS).
+    #[arg(long)]
+    pub patchelf: Option<PathBuf>,
+    /// Dynamic linker interpreter path (Linux only).
+    #[arg(long)]
+    pub interpreter: Option<PathBuf>,
+    /// Additional RPATH entries (colon-separated).
+    #[arg(long)]
+    pub rpath: Option<String>,
+}
+
+#[derive(Args)]
+pub struct NixInfoArgs {
+    /// Path to the virtual environment.
+    /// Defaults to UV_PROJECT_ENVIRONMENT, VIRTUAL_ENV, or .venv.
+    pub path: Option<PathBuf>,
+    /// Show verbose output including individual binaries and RPATH entries.
+    #[arg(long)]
+    pub show_details: bool,
+    /// Output as JSON.
+    #[arg(long)]
+    pub json: bool,
+    /// Show build configuration for a specific package instead of venv info.
+    #[arg(short, long)]
+    pub package: Option<String>,
+}
+
+#[derive(Args)]
+pub struct NixGenArgs {
+    /// Path to the virtual environment.
+    /// Defaults to UV_PROJECT_ENVIRONMENT, VIRTUAL_ENV, or .venv.
+    pub venv: Option<PathBuf>,
+    /// Write output to a file instead of stdout.
+    #[arg(short, long)]
+    pub output: Option<PathBuf>,
+    /// Only generate the native library override overlay, not the full package.nix.
+    #[arg(long)]
+    pub overlay_only: bool,
+    /// Prefer source distributions over wheels.
+    #[arg(long)]
+    pub no_prefer_wheels: bool,
+}
