+#[derive(Args)]
+pub struct NixNamespace {
+    #[command(subcommand)]
+    pub command: NixCommand,
+}
+
+#[derive(Subcommand)]
+pub enum NixCommand {
+    /// Print a hello message (proof of concept).
+    Hello(NixHelloArgs),
+    /// Patch ELF binaries in a virtual environment for NixOS compatibility.
+    PatchEnv(NixPatchEnvArgs),
+    /// Patch a managed Python installation for NixOS compatibility.
+    PatchPython(NixPatchPythonArgs),
+}
+
+#[derive(Args)]
+pub struct NixHelloArgs {
+    /// An optional name to greet.
+    #[arg(long)]
+    pub name: Option<String>,
+}
+
+#[derive(Args)]
+pub struct NixPatchEnvArgs {
+    /// Path to the virtual environment to patch.
+    pub path: PathBuf,
+    /// Path to the patchelf binary.
+    #[arg(long)]
+    pub patchelf: Option<PathBuf>,
+    /// Dynamic linker interpreter path.
+    #[arg(long)]
+    pub interpreter: Option<PathBuf>,
+    /// RPATH entries (colon-separated).
+    #[arg(long)]
+    pub rpath: Option<String>,
+}
+
+#[derive(Args)]
+pub struct NixPatchPythonArgs {
+    /// Path to the Python installation directory.
+    pub path: PathBuf,
+    /// Path to the patchelf binary.
+    #[arg(long)]
+    pub patchelf: Option<PathBuf>,
+    /// Dynamic linker interpreter path.
+    #[arg(long)]
+    pub interpreter: Option<PathBuf>,
+    /// RPATH entries (colon-separated).
+    #[arg(long)]
+    pub rpath: Option<String>,
+}
