@@ -850,6 +850,17 @@ async fn execute_plan(
             // task.
             .install_blocking(installs)?;

+        // Patch native binaries for Nix compatibility.
+        // Build dist-info prefixes (e.g. "numpy-2.4.6") so uv-nix can find
+        // exactly which files were just installed via their RECORD files.
+        let nix_dist_prefixes: Vec<String> = installs
+            .iter()
+            .map(|d| format!("{}-{}", d.filename().name.as_dist_info_name(), d.filename().version))
+            .collect();
+        for site_packages_dir in venv.site_packages() {
+            uv_nix::post_install_patch(&site_packages_dir, &nix_dist_prefixes)?;
+        }
+
         logger.on_install(installs.len(), start, printer, DryRun::Disabled)?;
     }

